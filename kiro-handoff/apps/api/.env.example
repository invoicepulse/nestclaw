# NestClaw API — Environment Variables
# Copy this to apps/api/.env and fill in all values before running

# ──────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/nestclaw?sslmode=require

# ──────────────────────────────────────────
# SUPABASE AUTH
# ──────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ──────────────────────────────────────────
# POLAR.SH BILLING
# ──────────────────────────────────────────
POLAR_ACCESS_TOKEN=polar_at_xxxxxxxxxxxx
POLAR_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
POLAR_PRODUCT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
POLAR_ORG_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ──────────────────────────────────────────
# RESEND EMAIL
# ──────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=hello@nestclaw.io

# ──────────────────────────────────────────
# CLOUDFLARE DNS
# ──────────────────────────────────────────
CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_ZONE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SERVER_IP=1.2.3.4   # Your Azure VM or Hetzner server IP

# ──────────────────────────────────────────
# CADDY ADMIN API
# ──────────────────────────────────────────
CADDY_ADMIN_URL=http://localhost:2019

# ──────────────────────────────────────────
# HOST SCRIPTS
# ──────────────────────────────────────────
HOST_SCRIPTS_PATH=/opt/nestclaw/scripts

# ──────────────────────────────────────────
# APP CONFIG
# ──────────────────────────────────────────
DOMAIN=nestclaw.io
PORT=2222
NODE_ENV=production
